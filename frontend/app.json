      "bundleIdentifier": "com.bharatnivesh.saathi"
    },
    "android": {
      "package": "com.bharatnivesh.saathi",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3a97d89e-11bc-4d4c-8136-705eb430b29c"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
