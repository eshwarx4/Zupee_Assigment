{
  "expo": {
    "name": "Bharat Nivesh Saathi",
    "slug": "bharat-nivesh-saathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
